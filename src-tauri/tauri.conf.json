{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cutout",
  "version": "1.0.5",
  "identifier": "com.fcatus.cutout",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Cutout",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 560,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": {
      "binaries/vision-bg-remove": "vision-bg-remove"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Photography",
    "copyright": "© 2026 fcatus",
    "shortDescription": "On-device background removal",
    "longDescription": "Drag in one or more images and Cutout removes their backgrounds using Apple's Vision framework — the same on-device subject-lifting model behind macOS. Fully offline, no bundled ML model, no uploads.",
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "-"
    }
  }
}
